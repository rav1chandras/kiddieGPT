STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=price_demo_monthly
STRIPE_YEARLY_PRICE_ID=price_demo_yearly
AUTH_TOKEN_SECRET=change_me_for_local_or_prod
ADMIN_EMAIL=admin@kiddiegpt.demo
ADMIN_PASSWORD=admin123
PARENT_TEST_EMAIL=parent.kiddiegpt@gmail.com
PARENT_TEST_PASSWORD=kiddiegpt123
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound
ALLOWED_PARENT_EMAIL_DOMAINS=gmail.com,yahoo.com,aol.com,outlook.com,hotmail.com
AUTH_TOKEN_TTL_HOURS=24
EMAIL_OTP_TTL_MINUTES=10
GOOGLE_CLIENT_ID=
REQUIRE_AUTH=true
# OpenAI key + model used by the portal AI proxy (extension never sees the key).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Cross-origin allow-list for the browser extension. Use "*" for dev, or a
# comma-separated list of chrome-extension://<id> origins for production.
ALLOWED_EXTENSION_ORIGINS=*
# How many days of per-child daily usage buckets to retain.
USAGE_RETENTION_DAYS=30
# Autopilot: time-based lifecycle automation (dunning, cancellation grace).
AUTOPILOT_ENABLED=true
# Days after first failed payment to send reminder emails (comma-separated).
DUNNING_REMINDER_DAYS=0,3,7
# Day after first failure to auto-suspend access if still unpaid.
DUNNING_SUSPEND_DAYS=10
# How often the background sweep runs, in minutes (file/Docker only; Vercel uses Cron).
SWEEP_INTERVAL_MINUTES=360

# ── Persistence ──────────────────────────────────────────────────────────────
# "file" (default) = atomic JSON-file DB, for local Docker.
# "postgres"        = single JSONB row in Postgres, for serverless/Vercel.
DB_DRIVER=file
# Required when DB_DRIVER=postgres (Vercel Postgres / Neon connection string).
POSTGRES_URL=
# Max Postgres pool connections per serverless instance.
PG_POOL_MAX=3
# Shared secret Vercel Cron sends (Authorization: Bearer <CRON_SECRET>) to
# /api/cron/sweep. Set it in prod so only Vercel Cron can trigger the sweep.
CRON_SECRET=
